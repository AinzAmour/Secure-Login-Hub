{
  "version": 2,
  "public": true,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/artifacts/api-server/src/index.ts"
    },
    {
      "source": "/(.*)",
      "destination": "/artifacts/secure-mfa/dist/public/$1"
    }
  ],
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/artifacts/secure-mfa/dist/public/index.html"
    }
  ]
}
